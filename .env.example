# ============================================
# crmAI - Railway Deployment Configuration
# ============================================

# --- Database (Railway PostgreSQL plugin) ---
DATABASE_URL=postgresql://user:password@railway-host:5432/crmai

# --- Redis (Railway Redis plugin) ---
REDIS_URL=redis://railway-host:6379

# --- JWT Secrets (generate strong secrets!) ---
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# --- API ---
API_PORT=3001

# --- Railway Service URLs (for web → api communication) ---
NEXT_PUBLIC_API_URL=https://api.up.railway.app/api/v1

# --- Prisma ---
# Railway auto-injects DATABASE_URL for Postgres plugin
# Prisma migration runs on deploy: npx prisma migrate deploy
DATABASE_URL_DEV=postgresql://postgres:postgres@localhost:5432/crmai
