{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.webapp",
    "watchPatterns": ["Dockerfile.web", "apps/web/**", "packages/**", "pnpm-lock.yaml", "pnpm-workspace.yaml", "package.json"]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
